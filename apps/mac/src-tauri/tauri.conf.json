{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://127.0.0.1:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Resolve",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "globalShortcut": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Productivity",
      "identifier": "ai.tiiny.resolve",
      "icon": [
        "icons/icon.icns"
      ]
    },
    "systemTray": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": false
    },
    "windows": [
      {
        "title": "Resolve",
        "width": 1180,
        "height": 820,
        "minWidth": 720,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
